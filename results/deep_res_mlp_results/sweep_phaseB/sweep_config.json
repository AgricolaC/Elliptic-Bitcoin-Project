{
  "sweep_id": "sweep_phaseB",
  "created_at": "2026-06-27",
  "purpose": "Focused graph-control sweep around the Phase A winner: K=3, hidden=[64,64], LayerNorm + SiLU, no residual.",
  "phaseA_source": "results/deep_res_mlp_results/sweep_phaseA/phaseA_summary.md",
  "output_folder": "results/deep_res_mlp_results/sweep_phaseB",
  "selection_policy": {
    "primary_metric": "Val_Macro_PRAUC",
    "secondary_metric": "Val_Pooled_PRAUC",
    "oot_metrics": "reported_only_not_used_for_selection"
  },
  "fixed_head": {
    "use_mlp_head": true,
    "use_layernorm": true,
    "activation": "silu",
    "use_residual": false,
    "mlp_hidden": [64, 64],
    "mlp_dropout": 0.3
  },
  "fixed_graph": {
    "sgc_k": 3,
    "use_multiscale_prop": true
  },
  "control_grid": {
    "variation": ["PCA", "Base"],
    "use_directional_prop": [true, false],
    "topology": ["late", "early", "none"]
  },
  "derived_config_rules": {
    "use_pca": "true iff variation == PCA",
    "pca_variance": 0.98,
    "use_graph_structural": "false iff topology == none",
    "topo_injection_mode": "late or early when topology is not none; late placeholder when topology is none"
  },
  "seeds": [42, 43, 44],
  "total_runs": 36,
  "training": {
    "loss": "weighted_cross_entropy",
    "focal_loss": false,
    "optimizer": "AdamW",
    "sgc_epochs": 200,
    "sgc_lr": 0.01,
    "sgc_weight_decay": 0.0005,
    "sgc_l1_lambda": 0.0001,
    "threshold": 0.5
  },
  "worker_caps": {
    "OMP_NUM_THREADS": 1,
    "OPENBLAS_NUM_THREADS": 1,
    "MKL_NUM_THREADS": 1,
    "NUMEXPR_NUM_THREADS": 1,
    "VECLIB_MAXIMUM_THREADS": 1,
    "torch_num_threads": 1
  },
  "expected_outputs": {
    "raw_results": "phaseB_results.csv",
    "aggregated_results": "phaseB_aggregated.csv",
    "summary": "phaseB_summary.md",
    "metadata": "phaseB_metadata.json"
  },
  "notes": [
    "This is a static-only graph-control sweep. Walk-forward is intentionally deferred.",
    "The sweep does not write to results/sweep_results.csv."
  ]
}
